[project]
name = "{{KAOS_PROJECT_SLUG}}-backend"
version = "0.1.0"
description = "{{KAOS_PROJECT_NAME}} backend"
requires-python = ">=3.14"
dependencies = [
    "fastapi[standard]>=0.115",
]
# To add KAOS packages: uv add kaos-core kaos-content kaos-pdf kaos-web

[dependency-groups]
dev = ["pytest>=8", "httpx>=0.27", "ruff>=0.11"]

[tool.ruff]
line-length = 100
target-version = "py314"

[tool.ruff.lint]
select = ["E", "F", "I", "B", "UP", "SIM", "RUF", "C4", "PTH"]
