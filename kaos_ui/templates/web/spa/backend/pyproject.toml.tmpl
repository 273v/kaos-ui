[build-system]
requires = ["hatchling>=1.27.0"]
build-backend = "hatchling.build"

[project]
name = "{{KAOS_PROJECT_SLUG}}-backend"
version = "0.1.0"
description = "{{KAOS_PROJECT_NAME}} backend — FastAPI on kaos-core"
readme = "../README.md"
requires-python = ">=3.13,<3.15"
license = { text = "MIT" }

dependencies = [
  # KAOS core + agentic + content + transports
  "kaos-core>=0.1.0",
  "kaos-agents>=0.1.0",
  "kaos-content[markdown,nlp]>=0.1.0",
  "kaos-llm-client>=0.1.0",
  "kaos-pdf>=0.1.0",
  "kaos-office>=0.1.0",
  # FastAPI + transport
  "fastapi>=0.115,<1.0",
  "uvicorn[standard]>=0.32,<1.0",
  "python-multipart>=0.0.20,<1",
  # sse-starlette handles ping, disconnect, graceful shutdown for SSE.
  # Raw StreamingResponse works but lacks these — see kaos-ui PATTERNS.
  "sse-starlette>=2.1,<3",
  # Settings + validation
  "pydantic>=2.11,<3",
  "pydantic-settings>=2.8,<3",
  # Magic-byte content-type verification (CWE-434 defense)
  "python-magic>=0.4.27,<1",
]

[project.optional-dependencies]
postgres = [
  "sqlalchemy>=2.0,<3",
  "asyncpg>=0.30,<1",
  "alembic>=1.13,<2",
]

[dependency-groups]
dev = [
  "httpx>=0.28,<1",
  "pytest>=8.3,<10",
  "pytest-asyncio>=0.26,<2",
  "pytest-cov>=6.0,<8",
  "ruff>=0.11,<2",
  "ty>=0.0.1a17",
]

[tool.hatch.build.targets.wheel]
packages = ["app"]

[tool.pytest.ini_options]
minversion = "8.0"
testpaths = ["tests"]
asyncio_mode = "auto"
asyncio_default_fixture_loop_scope = "function"
addopts = [
  "-ra",
  "--strict-markers",
  "--strict-config",
  "--cov=app",
  "--cov-branch",
  "--cov-report=term-missing",
]

[tool.ruff]
line-length = 100
target-version = "py313"

[tool.ruff.lint]
select = ["E", "F", "I", "B", "UP", "SIM", "RUF", "C4", "PTH", "S"]
# `S` is flake8-bandit — extra security signal. `S104` allows 0.0.0.0
# in dev (uvicorn binding) — opt out per-line if it fires.

[tool.coverage.run]
source = ["app"]
branch = true
