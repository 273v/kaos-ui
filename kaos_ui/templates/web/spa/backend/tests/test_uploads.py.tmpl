"""Upload route validation tests."""

from __future__ import annotations


def _login(client) -> None:
    client.post("/v1/auth/login", json={"token": "test-token-do-not-use-in-prod"})


def test_upload_accepts_text(client) -> None:
    _login(client)
    response = client.post(
        "/v1/uploads",
        files={"file": ("hello.txt", b"contents", "text/plain")},
    )
    assert response.status_code == 201
    body = response.json()
    assert body["filename"] == "hello.txt"
    assert body["extension"] == "txt"
    assert body["size_bytes"] == len(b"contents")
    assert body["document_id"]


def test_upload_rejects_disallowed_extension(client) -> None:
    _login(client)
    response = client.post(
        "/v1/uploads",
        files={"file": ("evil.exe", b"abc", "application/octet-stream")},
    )
    assert response.status_code == 400
    assert "not allowed" in response.json()["detail"]["message"]


def test_upload_rejects_oversize(client, monkeypatch) -> None:
    _login(client)
    # Set a tiny limit and try to upload more bytes.
    from app.settings import AppSettings
    from fastapi.testclient import TestClient

    from app.main import create_app

    monkeypatch.setenv("APP_MAX_UPLOAD_BYTES", "16")
    test_client = TestClient(create_app(AppSettings(_env_file=None)))
    test_client.post("/v1/auth/login", json={"token": "test-token-do-not-use-in-prod"})

    response = test_client.post(
        "/v1/uploads",
        files={"file": ("big.txt", b"x" * 17, "text/plain")},
    )
    assert response.status_code == 400
    assert "too large" in response.json()["detail"]["message"]
