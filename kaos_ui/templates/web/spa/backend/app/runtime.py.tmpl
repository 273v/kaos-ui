"""KaosRuntime factory.

The runtime is built once at lifespan startup and stashed on
``app.state.runtime``. FastAPI dependencies pull from there per request.
"""

from __future__ import annotations

import contextlib

from kaos_core import KaosRuntime
from kaos_core.tools import register_core_tools

from app.logging_setup import app_logger

logger = app_logger("runtime")


def build_runtime() -> KaosRuntime:
    """Build the application's KaosRuntime with all available tools."""
    runtime = KaosRuntime()
    n_core = register_core_tools(runtime)
    logger.info("registered %d core tools", n_core)

    n_extras = 0
    with contextlib.suppress(ImportError):
        from kaos_pdf import register_pdf_tools

        n_extras += register_pdf_tools(runtime)
    with contextlib.suppress(ImportError):
        from kaos_office import register_office_tools

        n_extras += register_office_tools(runtime)
    with contextlib.suppress(ImportError):
        from kaos_content.tools import register_content_tools

        n_extras += register_content_tools(runtime)

    logger.info("registered %d extra tools", n_extras)
    return runtime
