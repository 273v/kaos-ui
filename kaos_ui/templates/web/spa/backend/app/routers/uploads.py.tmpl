"""Upload route — multipart, server-side validated."""

from __future__ import annotations

from typing import Annotated

from app.deps import get_settings
from app.exceptions import UploadError
from app.services import uploads as upload_service
from app.settings import AppSettings
from fastapi import APIRouter, Depends, File, HTTPException, UploadFile, status
from pydantic import BaseModel

router = APIRouter(tags=["uploads"])


class UploadResponse(BaseModel):
    document_id: str
    filename: str
    extension: str
    size_bytes: int


# Streamed-read chunk size. Big enough to amortize per-chunk overhead,
# small enough that a malicious sender pushing past the cap is caught
# within a few chunks even on the largest configured limit.
_UPLOAD_CHUNK_BYTES = 256 * 1024  # 256 KiB


@router.post("", response_model=UploadResponse, status_code=status.HTTP_201_CREATED)
async def upload_route(
    settings: Annotated[AppSettings, Depends(get_settings)],
    file: Annotated[UploadFile, File()],
) -> UploadResponse:
    # Stream the upload chunk-by-chunk and short-circuit as soon as the
    # accumulated size exceeds the cap. Caddy enforces the same limit
    # at the proxy edge, but a direct hit on uvicorn / dev / an
    # alternate proxy bypasses that — without this loop the whole
    # body would be buffered into RAM before any size check runs.
    max_bytes = settings.max_upload_bytes
    parts: list[bytes] = []
    total = 0
    while True:
        chunk = await file.read(_UPLOAD_CHUNK_BYTES)
        if not chunk:
            break
        total += len(chunk)
        if total > max_bytes:
            # 413 — the canonical "payload too large" outcome. Don't
            # keep reading; drain whatever's still in flight via close.
            await file.close()
            raise HTTPException(
                status_code=status.HTTP_413_REQUEST_ENTITY_TOO_LARGE,
                detail={
                    "what": (f"Upload exceeded {max_bytes} bytes (read {total} before aborting)."),
                    "how_to_fix": ("Shrink the file or raise APP_MAX_UPLOAD_BYTES."),
                    "alternative": "Split the file and upload the parts.",
                },
            )
        parts.append(chunk)
    payload = b"".join(parts)
    filename = file.filename or "unknown"
    try:
        result = upload_service.store(filename, payload, settings)
    except UploadError as exc:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail={"what": str(exc).split("\n", 1)[0], "message": str(exc)},
        ) from exc
    return UploadResponse(
        document_id=result.document_id,
        filename=result.filename,
        extension=result.extension,
        size_bytes=result.size_bytes,
    )
