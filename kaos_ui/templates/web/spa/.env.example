# {{KAOS_PROJECT_NAME}} — environment variables
#
# Copy to .env and fill. The backend refuses to start in production
# without APP_AUTH_TOKEN; in development a missing token still raises.

# Required: long random string used as the bearer for the dashboard.
# Generate one with:  head -c 32 /dev/urandom | base64
APP_AUTH_TOKEN=

# Environment: development | production | test
APP_ENV=development

# Debug mode. Must be false in production.
APP_DEBUG=false

# Logging level (DEBUG, INFO, WARNING, ERROR)
APP_LOG_LEVEL=INFO

# CORS — explicit allowlist. Comma-separated; never `*` with credentials.
# Dev includes the Vite dev server origin.
APP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# LLM provider configuration. The chat endpoint uses these.
# Supported providers: anthropic, openai, google, xai, groq, mistral, openrouter
#
# Default tier: frontier reasoning. If you ship this template to a
# professional / legal / medical / financial audience, do NOT
# downshift to a "haiku" / "mini" / "nano" tier — the inference cost
# delta to a real model is negligible against the cost of a wrong
# answer. Override only for routine in-product UX (autocomplete,
# title suggestions, classification) where speed dominates accuracy.
APP_LLM_PROVIDER=anthropic
APP_LLM_MODEL=claude-opus-4-7

# Provider API keys — at least one must match APP_LLM_PROVIDER.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=

# VFS path (where state lives). In production mount this as a volume.
APP_VFS_PATH=.kaos-vfs

# Database — SQLite default. For Postgres set this AND use the
# docker-compose.postgres.yml overlay.
# APP_DATABASE_URL=postgresql+asyncpg://postgres:secret@postgres:5432/{{KAOS_PROJECT_SLUG}}

# Upload limits
APP_MAX_UPLOAD_BYTES=26214400
# APP_ALLOWED_UPLOAD_TYPES=pdf,docx,csv

# Frontend env (Vite). Read at build time only.
VITE_API_URL=/v1
