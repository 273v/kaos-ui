[build-system]
requires = ["hatchling>=1.27.0"]
build-backend = "hatchling.build"

[project]
name = "{{KAOS_PROJECT_SLUG}}"
version = "0.1.0"
description = "{{KAOS_PROJECT_NAME}} — KAOS-native Textual TUI"
readme = "README.md"
requires-python = ">=3.13,<3.15"
license = { text = "MIT" }

dependencies = [
  # KAOS core
  "kaos-core>=0.1.0",
  "kaos-agents>=0.1.0",
  "kaos-content[markdown]>=0.1.0",
  "kaos-llm-client>=0.1.0",
  # Textual — pin the major. Minor versions break snapshots / occasionally
  # rename CSS variables. Bump deliberately on Textual upgrades. Streaming
  # via Markdown.get_stream requires >=4.0, the "Streaming Release".
  "textual>=8.0,<9.0",
  "pydantic>=2.11,<3",
  "pydantic-settings>=2.8,<3",
]

[project.scripts]
{{KAOS_PROJECT_SLUG}} = "{{KAOS_PYTHON_MODULE}}.app:run"

[dependency-groups]
dev = [
  "pre-commit>=4.0,<5",
  "pytest>=8.3,<10",
  "pytest-asyncio>=0.26,<2",
  "pytest-cov>=6.0,<8",
  "ruff>=0.11,<2",
  "ty>=0.0.1a17",
  "textual-dev>=1.7,<2",
]

[tool.hatch.build.targets.wheel]
packages = ["{{KAOS_PYTHON_MODULE}}"]

[tool.hatch.build.targets.sdist]
include = [
  "/{{KAOS_PYTHON_MODULE}}",
  "/README.md",
  "/CLAUDE.md",
  "/tests",
]

[tool.pytest.ini_options]
minversion = "8.0"
testpaths = ["tests"]
asyncio_mode = "auto"
asyncio_default_fixture_loop_scope = "function"
addopts = [
  "-ra",
  "--strict-markers",
  "--strict-config",
  "--cov={{KAOS_PYTHON_MODULE}}",
  "--cov-branch",
  "--cov-report=term-missing",
]
markers = [
  "smoke: quick end-to-end checks",
]

[tool.ruff]
line-length = 100
target-version = "py313"

[tool.ruff.lint]
select = ["E", "F", "I", "B", "UP", "SIM", "RUF", "C4", "PTH"]

[tool.coverage.run]
source = ["{{KAOS_PYTHON_MODULE}}"]
branch = true
