# Environment: development | production | test
APP_ENV=development

# Debug mode. Must be False when APP_ENV=production.
APP_DEBUG=false

# Logging level (DEBUG, INFO, WARNING, ERROR). Logs go to a file —
# Textual owns stdout/stderr while running.
APP_LOG_LEVEL=INFO

# LLM provider configuration. The chat screen uses these.
# Supported providers: anthropic, openai, google, xai, groq, mistral, openrouter
APP_LLM_PROVIDER=anthropic
APP_LLM_MODEL=claude-haiku-4-5

# Provider API keys — at least one must match APP_LLM_PROVIDER.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=

# Where session memory + chat history live. XDG-friendly default.
# Override if you want a per-project VFS.
# APP_VFS_PATH=~/.kaos/{{KAOS_PROJECT_SLUG}}/vfs
