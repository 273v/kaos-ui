"""Upload validation tests."""

from __future__ import annotations

import pytest

from {{KAOS_PYTHON_MODULE}}.exceptions import UploadError
from {{KAOS_PYTHON_MODULE}}.services import uploads as upload_service
from {{KAOS_PYTHON_MODULE}}.settings import AppSettings


class _FakeFile:
    def __init__(self, name: str, payload: bytes) -> None:
        self.name = name
        self._payload = payload

    def getvalue(self) -> bytes:
        return self._payload


def _settings() -> AppSettings:
    return AppSettings(_env_file=None)


def test_rejects_oversize() -> None:
    settings = _settings()
    big = b"x" * (settings.max_upload_bytes + 1)
    with pytest.raises(UploadError, match="too large"):
        upload_service.validate(_FakeFile("big.txt", big), settings)


def test_rejects_disallowed_extension() -> None:
    settings = _settings()
    with pytest.raises(UploadError, match="not allowed"):
        upload_service.validate(_FakeFile("evil.exe", b"abc"), settings)


def test_accepts_allowed_extension() -> None:
    settings = _settings()
    ext, payload = upload_service.validate(_FakeFile("doc.txt", b"hello"), settings)
    assert ext == "txt"
    assert payload == b"hello"


def test_store_writes_to_vfs() -> None:
    settings = _settings()
    file = _FakeFile("hello.txt", b"contents")
    result = upload_service.store(file, runtime=None, settings=settings)
    assert result.vfs_path.read_bytes() == b"contents"
    assert result.document_id


def test_store_rejects_bad_input() -> None:
    settings = _settings()
    with pytest.raises(UploadError):
        upload_service.store(_FakeFile("x.exe", b"x"), runtime=None, settings=settings)


def test_rejects_renamed_file(monkeypatch: pytest.MonkeyPatch) -> None:
    """An ELF binary renamed .pdf must be rejected by magic-byte check
    (when libmagic is available). When libmagic is not installed the
    test asserts the warning path runs without crashing."""
    settings = _settings()
    elf_header = b"\x7fELF" + b"\x00" * 100  # ELF magic, fake binary

    try:
        import magic  # noqa: F401

        with pytest.raises(UploadError, match="content does not match"):
            upload_service.validate(_FakeFile("disguised.pdf", elf_header), settings)
    except ImportError:
        # libmagic not installed — verify graceful degradation.
        ext, _ = upload_service.validate(_FakeFile("disguised.pdf", elf_header), settings)
        assert ext == "pdf"  # extension check passed; magic check skipped


def test_document_id_has_no_path_separators() -> None:
    """The document_id is used as a directory name; it must be safe."""
    doc_id = upload_service._make_document_id("../etc/passwd")
    assert "/" not in doc_id
    assert "\\" not in doc_id
    assert ".." not in doc_id
    assert "\x00" not in doc_id
