"""Logging configuration regression tests.

These exist because of a real bug we shipped: ``_HumanFormatter`` was
re-running ``% args`` on an already-substituted message. Any
``logger.info("X %d", n)`` call would crash uvicorn/streamlit with
``TypeError: not all arguments converted during string formatting``.

The fix is in ``logging_setup._HumanFormatter`` — it clears
``record.args`` after substitution. This test pins that fix in place.
"""

from __future__ import annotations

import logging

from {{KAOS_PYTHON_MODULE}}.logging_setup import _HumanFormatter, _JsonFormatter


def _make_record(msg: str, *args: object) -> logging.LogRecord:
    return logging.LogRecord(
        name="kaos.app.{{KAOS_PROJECT_SLUG}}.test",
        level=logging.INFO,
        pathname=__file__,
        lineno=0,
        msg=msg,
        args=args or None,
        exc_info=None,
    )


def test_human_formatter_handles_percent_args() -> None:
    record = _make_record("registered %d core tools", 7)
    output = _HumanFormatter("%(message)s").format(record)
    assert "registered 7 core tools" in output


def test_json_formatter_handles_percent_args() -> None:
    record = _make_record("user %s logged in", "alice")
    output = _JsonFormatter().format(record)
    assert '"user alice logged in"' in output


def test_human_formatter_strips_crlf() -> None:
    """CRLF in user-controlled content must not forge log lines (CWE-117)."""
    record = _make_record("note: hello\r\nINJECTED FAKE LINE")
    output = _HumanFormatter("%(message)s").format(record)
    assert "INJECTED FAKE LINE" in output  # still appears
    assert "\r\n" not in output  # but not as a real newline
    assert "\\r\\n" in output or "\\nINJECTED" in output


def test_json_formatter_strips_crlf() -> None:
    record = _make_record("note: hello\r\nINJECTED")
    output = _JsonFormatter().format(record)
    # No raw CR/LF inside the JSON string value.
    assert "\r\n" not in output
