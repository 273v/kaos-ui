"""Settings tests — refusal-on-missing-token, redaction."""

from __future__ import annotations

import pytest

from {{KAOS_PYTHON_MODULE}}.exceptions import SettingsError
from {{KAOS_PYTHON_MODULE}}.settings import AppSettings


def test_refuses_to_start_without_token_in_dev(monkeypatch: pytest.MonkeyPatch) -> None:
    monkeypatch.setenv("APP_ENV", "development")
    monkeypatch.delenv("APP_AUTH_TOKEN", raising=False)
    with pytest.raises(SettingsError):
        AppSettings(_env_file=None)


def test_test_env_allows_missing_token(monkeypatch: pytest.MonkeyPatch) -> None:
    monkeypatch.setenv("APP_ENV", "test")
    monkeypatch.delenv("APP_AUTH_TOKEN", raising=False)
    AppSettings(_env_file=None)  # must not raise


def test_redaction_redacts_long_token(monkeypatch: pytest.MonkeyPatch) -> None:
    monkeypatch.setenv("APP_ENV", "test")
    monkeypatch.setenv("APP_AUTH_TOKEN", "abcdefghijklmnopqrstuvwxyz")
    settings = AppSettings(_env_file=None)
    payload = settings.model_dump_redacted()
    assert "abcdefghijklmnopqrstuvwxyz" not in str(payload)
    assert payload["auth_token"] == "abcd...wxyz"


def test_redaction_uses_stars_for_short_token(monkeypatch: pytest.MonkeyPatch) -> None:
    monkeypatch.setenv("APP_ENV", "test")
    monkeypatch.setenv("APP_AUTH_TOKEN", "short")
    settings = AppSettings(_env_file=None)
    assert settings.model_dump_redacted()["auth_token"] == "***"
