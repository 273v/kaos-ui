"""Smoke test — boot every page in headless mode.

We test pages individually because Streamlit's AppTest does not yet
fully render ``st.navigation``-routed pages when pointed at ``app.py``
(see https://github.com/streamlit/streamlit/issues/9446). Pointing
``AppTest.from_file`` directly at each page module is the supported
way to assert "this page renders without exception."
"""

from __future__ import annotations

import pytest
from streamlit.testing.v1 import AppTest

PAGE_PATHS = (
    "pages/chat.py",
    "pages/upload.py",
    "pages/search.py",
    "pages/browse.py",
    "pages/settings.py",
)


@pytest.mark.smoke
def test_app_root_boots() -> None:
    """``app.py`` boots and registers navigation. Page bodies are not
    rendered through this entrypoint per the AppTest gap noted above."""
    at = AppTest.from_file("app.py", default_timeout=30).run()
    assert at.exception == [], f"app.py raised: {at.exception}"


@pytest.mark.smoke
@pytest.mark.parametrize("page", PAGE_PATHS)
def test_each_page_renders(page: str) -> None:
    at = AppTest.from_file(page, default_timeout=30).run()
    assert at.exception == [], f"{page} raised: {at.exception}"
