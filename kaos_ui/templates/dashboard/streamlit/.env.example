# Required: long random string used as the dashboard's bearer token.
# Generate one with:  head -c 32 /dev/urandom | base64
APP_AUTH_TOKEN=

# Environment: development | production | test
# In production the app refuses to start with weak settings (short
# auth_token, weak literal, APP_DEBUG=true).
APP_ENV=development

# Debug mode. Must be False when APP_ENV=production (the app refuses
# to start otherwise).
APP_DEBUG=false

# Logging level (DEBUG, INFO, WARNING, ERROR)
APP_LOG_LEVEL=INFO

# LLM provider configuration. The chat page uses these.
# Supported providers: anthropic, openai, google, xai, groq, mistral, openrouter
#
# Default tier: frontier reasoning. Do NOT downshift to a "haiku" /
# "mini" / "nano" tier for professional / legal / medical / financial
# audiences — the inference cost delta is negligible against the
# liability cost of a wrong answer.
APP_LLM_PROVIDER=anthropic
APP_LLM_MODEL=claude-opus-4-7

# Provider API keys — at least one must match APP_LLM_PROVIDER.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=

# Where session memory, uploaded documents, and search indexes live.
# In production mount this path as a volume.
APP_VFS_PATH=.kaos-vfs

# File upload limits.
APP_MAX_UPLOAD_BYTES=26214400
# Comma-separated list. Defaults: pdf,docx,pptx,xlsx,csv,txt,md
# APP_ALLOWED_UPLOAD_TYPES=pdf,docx,csv

# Streamlit port (binds to 127.0.0.1 only)
APP_STREAMLIT_PORT=8501
