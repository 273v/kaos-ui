[project]
name = "{{KAOS_PROJECT_SLUG}}"
version = "0.1.0"
description = "{{KAOS_PROJECT_NAME}} — KAOS module"
requires-python = ">=3.14"
dependencies = [
    "kaos-core>=0.1",
    "kaos-content>=0.1",
]

[project.optional-dependencies]
mcp = ["kaos-mcp>=0.1"]

[project.scripts]
kaos-{{KAOS_PROJECT_SLUG}} = "{{KAOS_PYTHON_MODULE}}.cli:main"

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[dependency-groups]
dev = ["pytest>=8", "ruff>=0.11", "ty>=0.0.1a6"]

[tool.ruff]
line-length = 100
target-version = "py314"

[tool.ruff.lint]
select = ["E", "F", "I", "B", "UP", "SIM", "RUF", "C4", "PTH"]
