"""MCP server entry point for {{KAOS_PROJECT_NAME}}.

Usage:
    # stdio (default — for Claude Code, Codex, Gemini)
    {{KAOS_PROJECT_SLUG}}-serve

    # streamable HTTP
    {{KAOS_PROJECT_SLUG}}-serve --http --port 8000

    # debug logging
    {{KAOS_PROJECT_SLUG}}-serve --debug
"""

from __future__ import annotations

import argparse
import sys


def main(argv: list[str] | None = None) -> None:
    """Entry point for the MCP server."""
    parser = argparse.ArgumentParser(
        description="MCP server for {{KAOS_PROJECT_NAME}}",
    )
    parser.add_argument("--http", action="store_true", help="Use streamable HTTP transport")
    parser.add_argument("--host", default="127.0.0.1", help="HTTP host (default: 127.0.0.1)")
    parser.add_argument("--port", type=int, default=8000, help="HTTP port (default: 8000)")
    parser.add_argument("--debug", action="store_true", help="Enable debug logging")
    args = parser.parse_args(argv)

    try:
        from kaos_core import KaosRuntime
        from kaos_mcp import KaosMCPServer, KaosMCPSettings
    except ImportError:
        print(
            "Error: MCP server requires the 'mcp' extra.\n"
            "Install with: uv add '{{KAOS_PROJECT_SLUG}}[mcp]'",
            file=sys.stderr,
        )
        sys.exit(1)

    from {{KAOS_PYTHON_MODULE}} import register_{{KAOS_PYTHON_MODULE}}_tools

    runtime = KaosRuntime()
    n_tools = register_{{KAOS_PYTHON_MODULE}}_tools(runtime)
    print(f"Registered {n_tools} {{KAOS_PROJECT_NAME}} tools", file=sys.stderr)

    settings = KaosMCPSettings(
        name="{{KAOS_PROJECT_SLUG}}-server",
        transport="streamable-http" if args.http else "stdio",
        host=args.host,
        port=args.port,
        debug=args.debug,
    )

    server = KaosMCPServer(runtime=runtime, settings=settings)

    if args.http:
        print(f"Starting HTTP server on {args.host}:{args.port}/mcp", file=sys.stderr)
        server.run_streamable_http()
    else:
        print("Starting stdio server", file=sys.stderr)
        server.run_stdio()


if __name__ == "__main__":
    main()
