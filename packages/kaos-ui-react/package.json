{
  "name": "@273v/kaos-ui-react",
  "version": "0.1.0-alpha.11",
  "description": "React UI primitives for kaos-agents-powered chat surfaces \u2014 chat composer, transcript, file upload, citations panel, and a live run inspector.",
  "license": "Apache-2.0",
  "author": "273 Ventures, LLC <contact@273ventures.com>",
  "homepage": "https://github.com/273v/kaos-ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/273v/kaos-ui.git",
    "directory": "packages/kaos-ui-react"
  },
  "bugs": "https://github.com/273v/kaos-ui/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./chat": {
      "types": "./dist/chat/index.d.ts",
      "import": "./dist/chat/index.js",
      "require": "./dist/chat/index.cjs"
    },
    "./debug": {
      "types": "./dist/debug/index.d.ts",
      "import": "./dist/debug/index.js",
      "require": "./dist/debug/index.cjs"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js",
      "require": "./dist/hooks/index.cjs"
    },
    "./lib": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js",
      "require": "./dist/lib/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./tailwind.preset": "./dist/tailwind.preset.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "format": "biome format --write src",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5",
    "react": ">=19",
    "react-dom": ">=19",
    "tailwindcss": ">=4"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "dependencies": {
    "eventsource-parser": "^3.1.0",
    "lucide-react": "^1.17.0",
    "markdown-it": "^14.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@tanstack/react-query": "5.100.14",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwindcss": "4.3.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
