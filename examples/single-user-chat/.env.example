# Single-User Chat — environment variables
#
# Copy to .env and fill. Production refuses to start without the API token
# OR the localhost-dev escape hatch.

# ─────────────────────────────────────────────────────────────────────
#  kaos-agents HTTP API (owned by `kaos_agents.api.server.create_app()`)
# ─────────────────────────────────────────────────────────────────────
#
# WARNING — env var names use a DOUBLE "API_" prefix. This is a pydantic-
# settings + env_prefix quirk in kaos-agents 0.1.0a1; the package's own
# error message reports the single-API_ name, which DOES NOT WORK.
# See docs/PATTERNS.md P-001.

# Bearer token. Required in production. Generate one with:
#   head -c 32 /dev/urandom | base64
# Must be ≥ 32 chars.
KAOS_AGENTS_API_API_TOKEN=

# CORS — explicit allowlist. Dev includes the Vite dev server origin.
KAOS_AGENTS_API_API_CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Localhost-dev escape hatch. Only honored when the token is unset.
# Refuses everything that isn't 127.0.0.1 / ::1 — TestClient fixtures
# need a real token, not this flag. See docs/PATTERNS.md P-002.
# KAOS_AGENTS_API_API_ALLOW_UNAUTH_LOCALHOST=1

# ─────────────────────────────────────────────────────────────────────
#  Example-specific defaults (read by app.settings.AppSettings)
# ─────────────────────────────────────────────────────────────────────

# Environment: development | production | test
APP_ENV=development

# Default model + system prompt for new sessions (per-session overrides
# via the settings drawer at runtime).
# Frontier-tier worker default — DO NOT downshift below gpt ≥ 5.4 /
# claude ≥ 4.5 / gemini ≥ 2.5 for an attorney-facing surface.
# Recommended: openai:gpt-5.4-mini (cost-balanced frontier). For
# hardest matters where reasoning depth matters more than throughput,
# flip to anthropic:claude-opus-4-7 or openai:gpt-5.5.
APP_DEFAULT_MODEL=openai:gpt-5.4-mini
APP_DEFAULT_SYSTEM_PROMPT=You are a helpful assistant.

# Whether new sessions start with KAOS read-only tools enabled.
APP_DEFAULT_TOOLS_ENABLED=false

# Per-turn USD budget cap. The agent emits BudgetExceeded if a turn
# would exceed this. Sized for "5 docs + ReAct fan-out + deliverable"
# under either gpt-5.4-mini (~$0.10-0.30) or opus-4-7 (~$0.40-0.60).
APP_TURN_BUDGET_USD=5.00

# Logging level (DEBUG, INFO, WARNING, ERROR)
APP_LOG_LEVEL=INFO

# VFS path (where session metadata + agent memory live). Mount as a
# volume in production.
APP_VFS_PATH=.kaos-vfs

# ─────────────────────────────────────────────────────────────────────
#  LLM provider keys (read by kaos-llm-client; legacy names honored)
# ─────────────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# XAI_API_KEY=

# ─────────────────────────────────────────────────────────────────────
#  Frontend (Vite, read at build time only)
# ─────────────────────────────────────────────────────────────────────

VITE_API_URL=/v1
